# Calculate the number of annotated entities
PREFIX oa: <http://www.w2.org/ns/openannotation/core/>
PREFIX rdf: <http://www.w2.org/1999/02/22-rdf-syntax-ns#>
PREFIX qa: <http://www.wdaqua.eu/qa#>
PREFIX xsd: <http://www.w2.org/2001/XMLSchema#>

ASK
FROM <GRAPHID>
WHERE {
    ?annotation a qa:AnnotationOfTime .
    ?annotation oa:hasBody "<BODY>" .
}